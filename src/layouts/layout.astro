---
import { existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import Canvas3DBackground from '../components/canvas-3d-background.astro';

interface Props {
  title: string;
  description?: string;
  /** URL или путь к изображению для превью в соцсетях (рекомендуется 1200×630) */
  ogImage?: string;
  /** og:type — 'website' для страниц, 'article' для постов блога */
  ogType?: 'website' | 'article';
  /** Не индексировать (noindex) */
  noIndex?: boolean;
}

const { title, description = 'Персональный сайт и блог js2me', ogImage, ogType = 'website', noIndex = false } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
// Превью: явный ogImage → иначе og-preview.png (1200×630, фото можно сделать меньше в кадре) → иначе me.jpg
const defaultPath = (() => {
  try {
    const publicDir = fileURLToPath(new URL('../../public', import.meta.url));
    return existsSync(`${publicDir}/og-preview.png`) ? '/og-preview.png' : '/me-small.jpg';
  } catch {
    return '/me-small.jpg';
  }
})();
const imagePath = ogImage ?? defaultPath;
const imageURL = imagePath.startsWith('http') ? imagePath : new URL(imagePath, Astro.site).href;
---
<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/jpeg" href="/me-small.jpg" />
    <link rel="apple-touch-icon" href="/me-small.jpg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="фронтенд, frontend, JavaScript, TypeScript, React, MobX, Effector, Redux, веб-разработка, разработка интерфейсов, архитектура фронтенда, веб-производительность, UI, UX, карьера разработчика, опыт разработки, блог о фронтенде, IT, программирование, Astro"
    />
    <meta name="author" content="js2me" />
    <meta name="application-name" content="js2me — блог о фронтенде и веб‑разработке" />
    <meta name="subject" content="Блог о фронтенд‑разработке, JavaScript и веб‑технологиях" />
    <meta name="category" content="IT, фронтенд‑разработка, веб‑разработка" />
    <meta name="theme-color" content="#020817" />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="js2me" />
    <meta property="og:locale" content="ru_RU" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />

    <script type="application/ld+json" is:inline>
      {JSON.stringify(
        {
          '@context': 'https://schema.org',
          '@type': 'WebSite',
          name: 'js2me',
          url: canonicalURL.origin,
          inLanguage: 'ru-RU',
          description,
          about: [
            'фронтенд-разработка',
            'JavaScript',
            'TypeScript',
            'React',
            'MobX',
            'Effector',
            'Redux',
            'веб-разработка',
            'архитектура фронтенда',
            'производительность веб-приложений',
            'best practices фронтенда',
            'Astro'
          ],
          creator: {
            '@type': 'Person',
            name: 'js2me',
            jobTitle: 'Frontend Engineer',
            description:
              'Фронтенд‑разработчик, делюсь опытом из мира JavaScript, TypeScript, React и современной веб‑разработки.'
          }
        },
        null,
        2
      )}
    </script>

    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script is:inline>
      fetch('https://unpkg.com/mobx-view-model-devtools/auto.global.js').then(async (response) => {
        const script = await response.text();
        const scriptElement = document.createElement('script');
        scriptElement.innerHTML = script;
        document.head.appendChild(scriptElement);
      });
    </script>
  </head>
  <body>
    <Canvas3DBackground />
    <slot />
  </body>
</html>

<div class="canvas-wrapper">
  <canvas id="hero-canvas" aria-hidden="true"></canvas>
</div>
<script>
  import { initCanvas3D, resizeCanvas3D, disposeCanvas3D } from './canvas-3d-background';

  const canvas = document.getElementById('hero-canvas');
  if (canvas instanceof HTMLCanvasElement) {
    canvas.classList.add('is-booting');
    initCanvas3D(canvas);
    const ro = new ResizeObserver(() => resizeCanvas3D(canvas));
    ro.observe(canvas);
    // Даём three.js отрисовать первый кадр и плавно показываем canvas.
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        canvas.classList.remove('is-booting');
        canvas.classList.add('is-ready');
      });
    });
    window.addEventListener('beforeunload', () => {
      ro.disconnect();
      disposeCanvas3D();
    });
  }
</script>
<style>
  .canvas-wrapper {
    position: fixed;
    inset: 0;
    z-index: -1;
    background-color: #000;
    background-image: url('/fallback.jpg');
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
  }
  #hero-canvas {
    width: 100%;
    height: 100%;
    display: block;
    opacity: 0;
    transition: opacity 800ms ease;
    will-change: opacity;
  }
  #hero-canvas.is-ready {
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    #hero-canvas {
      transition: none;
    }
  }
</style>

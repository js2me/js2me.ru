<div class="canvas-wrapper">
  <canvas aria-hidden="true" data-hero-canvas></canvas>
</div>
<script>
  import { initCanvas3D, resizeCanvas3D, disposeCanvas3D } from './canvas-3d-background';

  let ro: ResizeObserver | null = null;
  let isInitialized = false;

  const setupCanvas = () => {
    if (isInitialized) return;

    const canvas = document.querySelector('[data-hero-canvas]');
    if (!(canvas instanceof HTMLCanvasElement)) return;

    canvas.classList.add('is-booting');
    initCanvas3D(canvas);

    ro = new ResizeObserver(() => resizeCanvas3D(canvas));
    ro.observe(canvas);

    // Даём three.js отрисовать первый кадр и плавно показываем canvas.
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        canvas.classList.remove('is-booting');
        canvas.classList.add('is-ready');
      });
    });

    isInitialized = true;
  };

  const cleanupCanvas = () => {
    if (!isInitialized) return;

    if (ro) {
      ro.disconnect();
      ro = null;
    }
    disposeCanvas3D();
    isInitialized = false;
  };

  setupCanvas();
</script>
<style>
  .canvas-wrapper {
    position: fixed;
    inset: 0;
    z-index: -1;
    background-color: #000;
    background-image: url('/fallback.jpg');
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
  }
  .canvas-wrapper canvas {
    width: 100%;
    height: 100%;
    display: block;
    opacity: 0;
    transition: opacity 800ms ease;
    will-change: opacity;
  }
  .canvas-wrapper canvas.is-ready {
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .canvas-wrapper canvas {
      transition: none;
    }
  }
</style>

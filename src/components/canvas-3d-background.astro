<div class="canvas-wrapper">
  <canvas aria-hidden="true" data-hero-canvas></canvas>
</div>
<script>
  import { initCanvas3D, resizeCanvas3D, disposeCanvas3D, setMousePosition, clearMousePosition, setScrollDelta } from './canvas-3d-background';

  let ro: ResizeObserver | null = null;
  let isInitialized = false;
  let onMove: ((e: MouseEvent) => void) | null = null;
  let onTouch: ((e: TouchEvent) => void) | null = null;
  let onLeave: (() => void) | null = null;
  let onScroll: (() => void) | null = null;
  let lastScrollY = 0;

  const setupCanvas = () => {
    if (isInitialized) return;

    const canvas = document.querySelector('[data-hero-canvas]');
    if (!(canvas instanceof HTMLCanvasElement)) return;

    canvas.classList.add('is-booting');
    initCanvas3D(canvas);

    onMove = (e: MouseEvent) => setMousePosition(e.clientX, e.clientY);
    onTouch = (e: TouchEvent) => {
      if (e.touches.length > 0) setMousePosition(e.touches[0].clientX, e.touches[0].clientY);
    };
    onLeave = () => clearMousePosition();

    window.addEventListener('mousemove', onMove, { passive: true });
    window.addEventListener('touchmove', onTouch, { passive: true });
    window.addEventListener('mouseleave', onLeave);
    document.addEventListener('touchcancel', onLeave);

    lastScrollY = window.scrollY;
    onScroll = () => {
      const y = window.scrollY;
      setScrollDelta(y - lastScrollY);
      lastScrollY = y;
    };
    window.addEventListener('scroll', onScroll, { passive: true });

    ro = new ResizeObserver(() => resizeCanvas3D(canvas));
    ro.observe(canvas);

    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        canvas.classList.remove('is-booting');
        canvas.classList.add('is-ready');
      });
    });

    isInitialized = true;
  };

  const cleanupCanvas = () => {
    if (!isInitialized) return;

    if (onMove) {
      window.removeEventListener('mousemove', onMove);
      onMove = null;
    }
    if (onTouch) {
      window.removeEventListener('touchmove', onTouch);
      onTouch = null;
    }
    if (onLeave) {
      window.removeEventListener('mouseleave', onLeave);
      document.removeEventListener('touchcancel', onLeave);
      onLeave = null;
    }
    if (onScroll) {
      window.removeEventListener('scroll', onScroll);
      onScroll = null;
    }
    if (ro) {
      ro.disconnect();
      ro = null;
    }
    disposeCanvas3D();
    isInitialized = false;
  };

  setupCanvas();
</script>
<style>
  .canvas-wrapper {
    position: fixed;
    inset: 0;
    z-index: -1;
    background-color: #000;
    background-image: url('/fallback.jpg');
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
  }
  .canvas-wrapper canvas {
    width: 100%;
    height: 100%;
    display: block;
    opacity: 0;
    transition: opacity 800ms ease;
    will-change: opacity;
  }
  .canvas-wrapper canvas.is-ready {
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .canvas-wrapper canvas {
      transition: none;
    }
  }
</style>
